#ASDF
#. /opt/homebrew/opt/asdf/libexec/asdf.sh

# Lazy-load asdf for faster shell startup
asdf() {
  unfunction asdf
  . $HOMEBREW_PREFIX/opt/asdf/libexec/asdf.sh
  asdf "$@"
}
export PATH="$HOME/.local/bin:${ASDF_DATA_DIR:-$HOME/.asdf}/shims:$PATH"
